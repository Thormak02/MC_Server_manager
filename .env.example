# Example environment configuration

MCSM_SECRET_KEY=CHANGE_ME_IN_ENV
MCSM_INITIAL_SUPERADMIN_USERNAME=admin
MCSM_INITIAL_SUPERADMIN_PASSWORD=admin123!

# Database
MCSM_SQLITE_PATH=data/mc_server_manager.db

# Scheduler / restart behaviour
MCSM_SCHEDULER_TIMEZONE=Europe/Berlin
MCSM_INGAME_RESTART_DELAY_SECONDS=30
MCSM_INGAME_RESTART_WARNING_MESSAGE=Server restartet in {seconds} Sekunden aufgrund /restart.

# Provisioning
MCSM_PROVISIONING_OFFLINE_MODE=false
MCSM_DEFAULT_SERVER_ROOT=
MCSM_DEFAULT_BACKUP_ROOT=

# External APIs
MCSM_CURSEFORGE_API_KEY=CHANGE_ME
MCSM_MODRINTH_USER_AGENT=mc-server-manager/1.0
